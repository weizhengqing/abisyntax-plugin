{
  "name": "abisyntax",
  "displayName": "ABINIT Syntax Highlighting",
  "description": "Syntax highlighting and language support for ABINIT input and output files.",
  "version": "1.0.8",
  "publisher": "weizhengqing",
  "repository": {
    "type": "git",
    "url": "https://github.com/weizhengqing/abisyntax-plugin"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "abinit",
        "aliases": ["ABINIT", "abinit"],
        "extensions": [".abi", ".in", ".inc"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "abinit-output",
        "aliases": ["ABINIT Output", "abinit-output"],
        "extensions": [".abo", ".output", ".log", ".err"],
        "filenames": ["DEN", "GSR"],
        "filenamePatterns": ["*_EIG", "*_DDB", "*_DEN", "*_POT"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "abinit",
        "scopeName": "source.abinit",
        "path": "./syntaxes/abinit.tmLanguage.json"
      },
      {
        "language": "abinit-output",
        "scopeName": "source.abinit-output",
        "path": "./syntaxes/abinit-output.tmLanguage.json"
      }
    ]
  }
}
