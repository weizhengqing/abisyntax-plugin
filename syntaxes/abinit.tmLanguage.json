    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.abinit",
          "match": "(?<![a-zA-Z0-9_\\\\.])([-\\+]?[0-9]*\\.?[0-9]+([dDeE][-\\+]?[0-9]+)?)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.abinit",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.abinit",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.abinit",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.abinit",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "units": {
      "patterns": [
        {
          "name": "keyword.other.unit.abinit",
          "match": "(?i)\\b(Bohr|Bohrs|eV|Hartree|Ry|Rydberg|Ha|K|Angstrom|angdeg|cm-1|GPa|meV|THz|au)\\b"
        }
      ]
    },
    "filepaths": {
      "patterns": [
        {
          "match": "(?i)\\b(xyzfile|\\w+_prefix|\\w+_filepath)\\s+([^\\s]+)",
          "captures": {
            "1": {
              "name": "keyword.control.abinit"
            },
            "2": {
              "name": "string.unquoted.filepath.abinit"
            }
          }
        }
      ]
    }
  },
  "scopeName": "source.abinit"
